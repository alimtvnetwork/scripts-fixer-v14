{
  "install": { "apt": ["pdns-server", "pdns-backend-sqlite3"] },
  "verify": "pdns_server --version",
  "systemdUnit": "pdns",
  "configDropPath": "/etc/powerdns/pdns.d/99-script102.conf",
  "configTemplate": "# Generated by 102-install-dns-powerdns-auth\nlocal-address={LISTEN}\nlocal-port={PORT}\nlaunch=gsqlite3\ngsqlite3-database=/var/lib/powerdns/pdns.sqlite3",
  "defaults": { "port": "53", "listen": "0.0.0.0", "forwarders": [] }
}
