{
  "install": {
    "apt": ["coredns"],
    "binary": {
      "url": "https://github.com/coredns/coredns/releases/download/v1.11.3/coredns_1.11.3_linux_amd64.tgz",
      "dest": "/usr/local/bin/coredns"
    }
  },
  "verify": "coredns -version",
  "systemdUnit": "coredns",
  "configDropPath": "/etc/coredns/Corefile",
  "configTemplate": "# Generated by 107-install-dns-coredns\n.:{PORT} {\n    bind {LISTEN}\n    forward . {FORWARDERS}\n    cache 300\n    log\n    errors\n}",
  "defaults": { "port": "53", "listen": "0.0.0.0", "forwarders": ["1.1.1.1", "9.9.9.9"] }
}
