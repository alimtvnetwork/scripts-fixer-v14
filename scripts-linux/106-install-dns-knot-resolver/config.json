{
  "install": { "apt": ["knot-resolver"] },
  "verify": "kresd -V",
  "systemdUnit": "kresd@1",
  "configDropPath": "/etc/knot-resolver/kresd.conf.d/99-script106.conf",
  "configTemplate": "-- Generated by 106-install-dns-knot-resolver\nnet.listen(\"{LISTEN}\", {PORT})\npolicy.add(policy.all(policy.FORWARD({ {FORWARDERS} })))",
  "defaults": { "port": "53", "listen": "0.0.0.0", "forwarders": ["1.1.1.1", "9.9.9.9"] }
}
