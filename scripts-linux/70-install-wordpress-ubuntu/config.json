{
  "id": "70",
  "title": "Ubuntu WordPress installer (Nginx + PHP-FPM + MySQL/MariaDB + latest WordPress)",
  "prereqs": {
    "apt_refresh_mode": "none",
    "supported_apt_refresh_modes": ["none", "update", "upgrade", "dist-upgrade"],
    "apt_refresh_timeout_seconds": 1800,
    "_comment": "apt_refresh_mode runs BEFORE MySQL + PHP-FPM in the prereqs stage. 'none' skips. 'update' runs apt-get update -y. 'upgrade' runs update + apt-get upgrade -y --no-install-recommends. 'dist-upgrade' runs update + dist-upgrade. Override at runtime with --apt-refresh <mode>, --apt-update, or --apt-upgrade."
  },
  "components": {
    "mysql": {
      "default_engine": "mysql",
      "supported_engines": ["mysql", "mariadb"],
      "default_port": 3306,
      "default_data_dir": "/var/lib/mysql"
    },
    "php": {
      "default_version": "latest",
      "supported_versions": ["8.1", "8.2", "8.3", "latest"],
      "extensions": [
        "fpm", "mysql", "xml", "curl", "gd", "mbstring",
        "zip", "intl", "bcmath", "soap", "imagick", "cli"
      ]
    },
    "nginx": {
      "default_site_port": 80,
      "default_server_name": "localhost"
    },
    "wordpress": {
      "download_url": "https://wordpress.org/latest.tar.gz",
      "default_install_path": "/var/www/wordpress",
      "default_db_name": "wordpress",
      "default_db_user": "wp_user",
      "auto_generate_password": true
    }
  }
}